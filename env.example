# ─────────────────────────────────────────────────────────────────────────────
# FanNav — Environment Variables
# Copy this file to .env.local for local dev, then add each var to:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────


# ── PayPal ────────────────────────────────────────────────────────────────────
# From: developer.paypal.com → My Apps & Credentials → Your App

# Client ID (also used on frontend)
PAYPAL_CLIENT_ID=your_paypal_client_id_here

# Secret — NEVER expose this on the frontend
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Sandbox:  https://api-m.sandbox.paypal.com
# Live:     https://api-m.paypal.com
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Webhook ID — from PayPal Dashboard → Webhooks → Your Webhook
# (Available after you register https://your-project.vercel.app/api/paypal-webhook)
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here


# ── Supabase ──────────────────────────────────────────────────────────────────
# From: app.supabase.com → Your Project → Settings → API

SUPABASE_URL=https://xxxx.supabase.co

# Anon key — safe to use on frontend (used for wait_reports + RPC only)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — ONLY used server-side in edge functions, NEVER on frontend
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here


# ── Google Maps ───────────────────────────────────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Directions API, Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# ── App ───────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (used for CORS in edge functions)
ALLOWED_ORIGIN=https://your-project.vercel.app

# Public API base URL (used by frontend to call edge functions)
# Leave empty in production — Vercel serves /api/* from the same domain
NEXT_PUBLIC_API_URL=


# ─────────────────────────────────────────────────────────────────────────────
# SETUP CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Supabase
#    □ Create project at app.supabase.com
#    □ Run supabase-schema.sql in SQL Editor
#    □ Copy URL + anon key + service_role key here
#
# 2. PayPal
#    □ Create app at developer.paypal.com
#    □ Copy Client ID + Secret here
#    □ Set PAYPAL_BASE_URL to sandbox for testing, live for production
#    □ Deploy to Vercel first (step 4), then come back to register webhook
#
# 3. Google Maps
#    □ Enable Maps JS API, Directions API, Places API
#    □ Copy API key here
#    □ Restrict key to your domain in Google Cloud Console
#
# 4. Deploy to Vercel
#    □ npm create vite@latest fannav -- --template react
#    □ Copy fannav-app.jsx → src/App.jsx
#    □ Copy api/ folder and vercel.json to project root
#    □ vercel login && vercel --prod
#    □ Add all env vars in Vercel Dashboard
#
# 5. Register PayPal Webhook
#    □ Go to developer.paypal.com → Webhooks → Add Webhook
#    □ URL: https://your-project.vercel.app/api/paypal-webhook
#    □ Subscribe to:
#        PAYMENT.CAPTURE.COMPLETED
#        PAYMENT.CAPTURE.REFUNDED
#        PAYMENT.CAPTURE.REVERSED
#        PAYMENT.CAPTURE.DENIED
#    □ Copy Webhook ID → set PAYPAL_WEBHOOK_ID in Vercel env vars
#    □ Redeploy: vercel --prod
#
# ─────────────────────────────────────────────────────────────────────────────
